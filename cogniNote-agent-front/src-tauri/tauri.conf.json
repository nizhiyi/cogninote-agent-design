{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CogniNote",
  "version": "0.1.35",
  "identifier": "com.itqianchen.cogninote",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico"
    ],
    "resources": {
      "../../target/desktop/backend/CogniNoteBackend/": "backend/CogniNoteBackend/"
    },
    "windows": {
      "allowDowngrades": false,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installerHooks": "windows/hooks.nsh",
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://itqianchen.github.io/cogninote-agent-design/updater/stable/latest.json",
        "https://github.com/ItQianChen/cogninote-agent-design/releases/download/desktop-updater-stable/latest.json"
      ]
    }
  }
}
